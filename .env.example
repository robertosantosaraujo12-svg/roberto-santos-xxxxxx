# =========================================================================
# PLATAFORMA PIRAMIDY - CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE (.env)
# =========================================================================
#
# INSTRUÇÕES PARA O TÉCNICO / ADMINISTRADOR DO SISTEMA:
#
# 1. Copie este arquivo e nomeie a cópia como ".env" na raiz do projeto.
#    Exemplo: cp .env.example .env
#
# 2. Acesse o Console do Firebase (https://console.firebase.google.com/)
# 3. Se ainda não tiver um projeto criado, crie um novo projeto (ex: "Piramidy").
# 4. Ative os serviços necessários no painel esquerdo:
#    - Firestore Database (Banco de Dados NoSQL)
#    - Authentication (Ative os provedores de e-mail/senha ou outros desejados)
# 5. Adicione um Web App (aplicativo web) ao seu projeto Firebase:
#    - Vá em "Configurações do Projeto" (ícone de engrenagem no topo esquerdo).
#    - Na aba "Geral", role até a seção "Seus aplicativos".
#    - Clique no ícone "</>" (Web) para registrar o aplicativo.
#    - Dê um nome (ex: "Piramidy Web").
# 6. Copie os valores do objeto "firebaseConfig" que o Firebase irá gerar e 
#    cole-os abaixo, substituindo os valores de exemplo.
#
# ATENÇÃO: Em projetos Vite, as variáveis do lado do cliente DEVEM começar 
# com o prefixo "VITE_". Sem isso, o frontend não conseguirá lê-las!
#
# =========================================================================

# Chave de API pública do Firebase (Firebase Web API Key)
VITE_FIREBASE_API_KEY=sua_api_key_aqui_gerada_pelo_firebase

# Domínio de autenticação do Firebase (ex: seu-projeto.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com

# ID do projeto do Firebase (ex: piramidy-12345)
VITE_FIREBASE_PROJECT_ID=seu-projeto-id

# Bucket de armazenamento do Firebase Storage (ex: seu-projeto.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app

# ID do remetente de mensagens (Messaging Sender ID - numérico de 11-12 dígitos)
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id_aqui

# ID exclusivo do aplicativo Web (App ID - ex: 1:12345:web:abcdef)
VITE_FIREBASE_APP_ID=seu_app_id_aqui

# =========================================================================
# OBSERVAÇÃO PARA HOSPEDAGEM (PRODUÇÃO):
#
# Se estiver hospedando na Netlify, Vercel, Heroku, VPS ou servidor próprio:
# - Insira estas mesmas chaves e valores diretamente nas configurações de 
#   "Environment Variables" (Variáveis de Ambiente) do painel de controle
#   do seu provedor de hospedagem, ou use o arquivo .env criado localmente.
# =========================================================================
